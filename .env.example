# ==============================================================================
# Atelier Environment Variables Template
# Copy this file to '.env' and fill in your connection credentials.
# ==============================================================================

# PostgreSQL Connection String (Neon or Supabase)
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
DATABASE_URL="postgresql://user:password@ep-cool-shadow-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Redis Connection String (Upstash)
# Format: rediss://default:[password]@[host]:[port]
REDIS_URL="rediss://default:password@cool-camel-12345.upstash.io:6379"

# NVIDIA NIM API configuration for Nemotron LLM
# Point to https://integrate.api.nvidia.com/v1 via OpenAI-compatible SDK
NVIDIA_NIM_API_KEY="your_nvidia_nim_api_key_here"
NIM_MODEL_NAME="nvidia/nemotron-3-super-120b-a12b"

# Model Router API Keys & Custom Model Overrides
# Primary Provider Keys per Agent (falls back to NVIDIA NIM if missing/unconfigured)
GOOGLE_AI_API_KEY="your_google_ai_api_key_here"
GOOGLE_MODEL="gemini-2.5-flash"

GITHUB_MODELS_TOKEN="your_github_models_token_here"
GITHUB_MODEL="gpt-4o-mini"
GITHUB_VISION_MODEL="gpt-4o-mini"

MISTRAL_API_KEY="your_mistral_api_key_here"
MISTRAL_REASONING_MODEL="mistral-medium-3-5"
MISTRAL_CODE_MODEL="codestral-latest"

COHERE_API_KEY="your_cohere_api_key_here"
COHERE_MODEL="command-r-plus"

GROQ_API_KEY="your_groq_api_key_here"
GROQ_MODEL="llama-3.3-70b-versatile"

CEREBRAS_API_KEY="your_cerebras_api_key_here"
CEREBRAS_MODEL="llama3.1-70b"

CLOUDFLARE_API_KEY="your_cloudflare_api_key_here"
CLOUDFLARE_MODEL="@cf/meta/llama-3-8b-instruct"

HUGGINGFACE_API_KEY="your_huggingface_api_key_here"
HF_MODEL="meta-llama/Llama-3-8b-instruct"

OPENROUTER_API_KEY="your_openrouter_api_key_here"
OPENROUTER_MODEL="meta-llama/llama-3-8b-instruct"

# ElevenLabs Text-to-Speech API (optional — pitch videos will be silent without this)
# Sign up at https://elevenlabs.io — Free tier: 10k chars/month
ELEVENLABS_API_KEY="your_elevenlabs_api_key_here"

SKETCHFAB_API_TOKEN=your_sketchfab_api_token_here